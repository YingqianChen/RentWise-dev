# RentWise 环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# ==================== LLM 配置 ====================
# LLM 提供商选择: "groq" 或 "ollama"
LLM_PROVIDER=groq

# Groq API 配置 (推荐，免费)
# 注册地址: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama 配置 (需要校园网访问)
OLLAMA_HOST=your-server-address
OLLAMA_API_KEY=your-api-key
OLLAMA_MODEL=llama3.3:is6620

# ==================== 安全配置 ====================
# JWT 密钥 (生产环境必须修改为随机字符串)
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key

# ==================== 数据库配置 ====================
# 数据库URL (默认使用SQLite，生产环境可切换到PostgreSQL)
# SQLite: sqlite:///./rentwise.db
# PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./rentwise.db
