# RentWise Backend Environment

# Required
SECRET_KEY=your-secret-key-at-least-16-characters
DATABASE_URL=postgresql+asyncpg://<role>:<password>@<host>/<dbname>?ssl=require

# LLM Provider (choose one: groq or ollama)
LLM_PROVIDER=groq

# Groq Configuration (if using Groq)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama Configuration (if using Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=llama3.3

# Amap (Gaode) Map API — used for commute estimation
AMAP_API_KEY=

# Application
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

FILE_STORAGE_PROVIDER=local
# For Render or other ephemeral filesystems, use /tmp/... for short-lived local uploads
# LOCAL_UPLOAD_ROOT=/tmp/rentwise-storage
OCR_PROVIDER=rapidocr
# Cloud OCR (set OCR_PROVIDER=mistral to use). Recommended on memory-constrained
# hosts like Render free tier — moves OCR off-process so the API stays under 200MB.
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
OCR_SPACE_API_KEY=
PADDLEOCR_LANG=ch
OCR_USE_DOC_ORIENTATION=False
OCR_USE_DOC_UNWARPING=False
OCR_USE_TEXTLINE_ORIENTATION=False
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
LOW_MEMORY_MODE=False
OCR_PREWARM_ON_STARTUP=True
OCR_MAX_IMAGE_DIMENSION=1600
