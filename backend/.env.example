# RentWise Backend Environment

# Required
SECRET_KEY=your-secret-key-at-least-16-characters
DATABASE_URL=postgresql+asyncpg://<role>:<password>@<host>/<dbname>?ssl=require

# LLM Provider (choose one: groq or ollama)
LLM_PROVIDER=groq

# Groq Configuration (if using Groq)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama Configuration (if using Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=llama3.3

# Application
APP_ENV=development

FILE_STORAGE_PROVIDER=local
OCR_PROVIDER=rapidocr
PADDLEOCR_LANG=ch
OCR_USE_DOC_ORIENTATION=False
OCR_USE_DOC_UNWARPING=False
OCR_USE_TEXTLINE_ORIENTATION=False
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
OCR_PREWARM_ON_STARTUP=True
OCR_MAX_IMAGE_DIMENSION=1600
